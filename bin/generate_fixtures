  tipo_chave_dict: 'cnpj',
  valor_maximo_pix: 123.45,
  valor_minimo_pix: 123.45,
  txid: 'TXID20260416001'
)

# Bradesco
gera_remessa(
  Brcobranca::Remessa::Cnab400::Bradesco.new(
