  'banco_c6_carteira_20' => {
    class: Brcobranca::Boleto::BancoC6,
    attrs: { agencia: '0001', conta_corrente: '0000528', convenio: '000000123456', nosso_numero: '0000000001', carteira: '20' }
  },
  'banestes' => {
    class: Brcobranca::Boleto::Banestes,
