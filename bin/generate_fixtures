# --- Sumário ---
puts "\n=== Sumário ==="
pdf_count = Dir.glob("#{PDF_DIR}/*.pdf").size
rem_count = Dir.glob("#{REMESSA_DIR}/*.rem").size
puts "  PDFs gerados: #{pdf_count} em #{PDF_DIR}"
puts "  Remessas geradas: #{rem_count} em #{REMESSA_DIR}"
puts "\n✅ Geração concluída."
