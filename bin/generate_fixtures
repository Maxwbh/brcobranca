dados_comuns = {
  valor: 123.45,
  data_documento: Date.today,
  data_vencimento: Date.today + 30,
  cedente: 'Empresa Exemplo LTDA',
  documento_cedente: '12345678000100',
  **sacado_data
}

bancos_boleto.each do |nome, cfg|
  attrs = dados_comuns.merge(cfg[:attrs])
  boleto = cfg[:class].new(attrs)
  gera_pdf(boleto, nome)
end

# --- 2. Boletos PDF híbridos (com PIX) ---
puts "\n=== 2. Gerando boletos híbridos com PIX (Bolepix) ==="
Brcobranca.setup { |c| c.gerador = :rghost_bolepix }

bancos_bolepix = %w[
  banco_brasil bradesco caixa itau santander sicoob
  sicoob_carteira_9 banco_c6 banco_c6_carteira_20
]

bancos_bolepix.each do |nome|
  cfg = bancos_boleto[nome]
  attrs = dados_comuns.merge(cfg[:attrs]).merge(emv: EMV_EXEMPLO)
  boleto = cfg[:class].new(attrs)
  gera_pdf(boleto, "#{nome}_pix")
end

# --- 3. Boletos via Prawn (alternativa sem Ghostscript) ---
puts "\n=== 3. Gerando boletos via Prawn (alternativa sem Ghostscript) ==="

# Força o load do template Prawn (autoload não é suficiente para expor a constante)
require 'brcobranca/boleto/template/prawn_bolepix'

if Brcobranca::Boleto::Template::PRAWN_AVAILABLE
  Brcobranca.setup { |c| c.gerador = :rghost }

  # Boletos tradicionais (sem PIX) via Prawn - para comparação com RGhost
  %w[bradesco itau caixa sicoob banco_c6].each do |nome|
    cfg = bancos_boleto[nome]
    attrs = dados_comuns.merge(cfg[:attrs])
    boleto = cfg[:class].new(attrs)
    boleto.extend(Brcobranca::Boleto::Template::PrawnBolepix)

    path = File.join(PDF_DIR, "prawn_#{nome}.pdf")
    begin
      File.open(path, 'wb') { |f| f.write(boleto.to(:pdf)) }
      puts "  ✓ #{path} (#{File.size(path)} bytes)"
    rescue StandardError => e
      puts "  ✗ prawn_#{nome}: #{e.class}: #{e.message}"
    end
  end

  # Boletos com PIX/QRCode via Prawn
  %w[bradesco itau caixa sicoob banco_c6].each do |nome|
    cfg = bancos_boleto[nome]
    attrs = dados_comuns.merge(cfg[:attrs]).merge(emv: EMV_EXEMPLO)
    boleto = cfg[:class].new(attrs)
    boleto.extend(Brcobranca::Boleto::Template::PrawnBolepix)

    path = File.join(PDF_DIR, "prawn_#{nome}_pix.pdf")
    begin
      File.open(path, 'wb') { |f| f.write(boleto.to(:pdf)) }
      puts "  ✓ #{path} (#{File.size(path)} bytes)"
    rescue StandardError => e
      puts "  ✗ prawn_#{nome}_pix: #{e.class}: #{e.message}"
    end
  end
else
  puts '  (Prawn não disponível — install: gem install prawn barby rqrcode chunky_png)'
end

# --- 4. Arquivos de remessa CNAB 400 ---
puts "\n=== 4. Gerando arquivos de remessa CNAB 400 ==="

pagamento_padrao = Brcobranca::Remessa::Pagamento.new(
