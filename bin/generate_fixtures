#!/usr/bin/env ruby
# frozen_string_literal: true

# Script que gera:
#  1. Boletos PDF tradicionais (todos os 18 bancos) em spec/fixtures/generated/pdf/
#  2. Boletos PDF híbridos (com PIX/QR Code) para bancos que suportam
#  3. Arquivos de remessa CNAB 240/400 em spec/fixtures/generated/remessa/
#  4. Versão Prawn do boleto com PIX (quando disponível)
#
# Uso:
#   bin/generate_fixtures

# NÃO usa bundler/setup para permitir load de gems extras (prawn, rqrcode, etc.)
# instaladas via `gem install --user-install`.

$LOAD_PATH.unshift File.expand_path('../lib', __dir__)
require 'brcobranca'
require 'brcobranca/boleto/template/prawn_bolepix'
require 'fileutils'

# --- Diretórios de saída ---
PDF_DIR = File.expand_path('../spec/fixtures/generated/pdf', __dir__)
REMESSA_DIR = File.expand_path('../spec/fixtures/generated/remessa', __dir__)
FileUtils.mkdir_p(PDF_DIR)
FileUtils.mkdir_p(REMESSA_DIR)

# --- Dados comuns ---
EMV_EXEMPLO = '00020126580014br.gov.bcb.pix0136' \
              '123e4567-e12b-12d1-a456-4266554400005204000053039865802BR' \
              '5913EMPRESA TESTE6009SAO PAULO62070503***63049D3E'

sacado_data = {
  sacado: 'Cliente Teste da Silva',
  sacado_documento: '12345678900',
  sacado_endereco: 'Rua Exemplo, 123 - Centro - São Paulo/SP - 01000-000'
}

# --- Helpers ---
def gera_pdf(boleto, nome)
  path = File.join(PDF_DIR, "#{nome}.pdf")
  File.open(path, 'wb') { |f| f.write(boleto.to(:pdf)) }
  puts "  ✓ #{path} (#{File.size(path)} bytes)"
rescue StandardError => e
  puts "  ✗ #{nome}: #{e.class}: #{e.message}"
end

def gera_remessa(remessa, nome, ext = 'rem')
  path = File.join(REMESSA_DIR, "#{nome}.#{ext}")
  File.open(path, 'wb') { |f| f.write(remessa.gera_arquivo) }
  puts "  ✓ #{path} (#{File.size(path)} bytes)"
rescue StandardError => e
  puts "  ✗ #{nome}: #{e.class}: #{e.message}"
end

# --- 1. Boletos PDF tradicionais ---
puts "\n=== 1. Gerando boletos PDF tradicionais ==="
Brcobranca.setup { |c| c.gerador = :rghost }

bancos_boleto = {
  'banco_brasil' => {
    class: Brcobranca::Boleto::BancoBrasil,
    attrs: { agencia: '1234', conta_corrente: '12345', convenio: '1234567', nosso_numero: '1', carteira: '18', variacao: '019' }
  },
  'bradesco' => {
    class: Brcobranca::Boleto::Bradesco,
    attrs: { agencia: '1234', conta_corrente: '1234567', nosso_numero: '1', carteira: '06' }
  },
  'caixa' => {
    class: Brcobranca::Boleto::Caixa,
    attrs: { agencia: '1234', conta_corrente: '123456', convenio: '123456', nosso_numero: '123', carteira: '1' }
  },
  'itau' => {
    class: Brcobranca::Boleto::Itau,
    attrs: { agencia: '1234', conta_corrente: '12345', carteira: '175', nosso_numero: '12345678', seu_numero: '12345' }
  },
  'santander' => {
    class: Brcobranca::Boleto::Santander,
